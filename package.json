{
  "name": "code-review",
  "version": "0.1.0",
  "description": "Code Review App",
  "main": "dist/main.js",
  "scripts": {
    "build:prod": "webpack --mode production && electron-builder --dir",
    "dev": "webpack --mode development && electron . --dev",
    "start": "electron ."
  },
  "build": {
    "appId": "com.code-review.app",
    "productName": "code-review",
    "files": [
      "dist/**/*"
    ],
    "linux": {
      "target": "dir",
      "executableName": "code-review"
    },
    "mac": {
      "target": "dir"
    },
    "win": {
      "target": "dir"
    }
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "html-webpack-plugin": "^5.6.6",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
